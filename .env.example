# ============================================================
# AI-Powered SEO Automation Center — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Google Search Console (Service Account)
# Extract these from your searchConsoleClaude.json file.
# The private key must be a single line with literal \n chars.
# ------------------------------------------------------------
GSC_CLIENT_EMAIL=searchconsoleclaude@arboreal-drake-492012-e0.iam.gserviceaccount.com
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GSC_PROJECT_ID=arboreal-drake-492012-e0

# Comma-separated list of verified GSC property URLs.
# Use exact format as shown in GSC: https://example.com/ or sc-domain:example.com
GSC_SITES=https://site1.com/,https://site2.com/,sc-domain:site3.com

# ------------------------------------------------------------
# WordPress Sites (1 to 5)
# Generate Application Passwords: WP Admin > Users > Your Profile > Application Passwords
# Use a dedicated low-privilege user (Editor role), NOT admin.
# ------------------------------------------------------------
WP_1_URL=https://site1.com
WP_1_USERNAME=seo-bot
WP_1_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_1_LABEL=Site One

WP_2_URL=https://site2.com
WP_2_USERNAME=seo-bot
WP_2_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_2_LABEL=Site Two

WP_3_URL=https://site3.com
WP_3_USERNAME=seo-bot
WP_3_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_3_LABEL=Site Three

# WP_4 and WP_5 follow the same pattern — add if needed.

# ------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------
# "stdio"  → for Claude Desktop (process-based, no network port)
# "http"   → for Railway deployment (network-accessible)
MCP_TRANSPORT=stdio
PORT=3000
LOG_LEVEL=info
